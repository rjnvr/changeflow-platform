generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  project_manager
  accounting
}

enum ProjectStatus {
  active
  on_hold
  completed
}

enum ChangeOrderStatus {
  draft
  pending_review
  approved
  rejected
  synced
}

enum IntegrationStatus {
  connected
  disconnected
  error
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  firstName              String
  lastName               String
  passwordHash           String
  resetPasswordTokenHash String?      @unique
  resetPasswordExpiresAt DateTime?
  role                   UserRole
  projects               Project[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Project {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique
  location      String
  status        ProjectStatus @default(active)
  archivedAt    DateTime?
  contractValue Decimal       @db.Decimal(12, 2)
  ownerId       String
  owner         User          @relation(fields: [ownerId], references: [id])
  changeOrders  ChangeOrder[]
  teamMembers   ProjectTeamMember[]
  documents     ProjectDocument[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProjectTeamMember {
  id        String   @id @default(cuid())
  projectId String
  name      String
  role      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  title     String
  kind      String
  summary   String
  url       String?
  storageKey String?
  fileName   String?
  contentType String?
  fileSize   Int?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChangeOrder {
  id                String            @id @default(cuid())
  projectId         String
  title             String
  description       String
  status            ChangeOrderStatus @default(draft)
  archivedAt        DateTime?
  amount            Decimal           @db.Decimal(12, 2)
  requestedBy       String
  assignedTo        String?
  externalReference String?
  aiSummary         String?
  project           Project           @relation(fields: [projectId], references: [id])
  attachments       ChangeOrderAttachment[]
  comments          ChangeOrderComment[]
  auditLogs         AuditLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ChangeOrderAttachment {
  id            String      @id @default(cuid())
  changeOrderId String
  title         String
  storageKey    String
  fileName      String
  contentType   String
  fileSize      Int
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ChangeOrderComment {
  id            String      @id @default(cuid())
  changeOrderId String
  authorName    String
  body          String
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model IntegrationConnection {
  id          String            @id @default(cuid())
  provider    String            @unique
  status      IntegrationStatus @default(disconnected)
  lastSyncedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AuditLog {
  id            String       @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  changeOrderId String?
  metadata      Json?
  changeOrder   ChangeOrder? @relation(fields: [changeOrderId], references: [id])
  createdAt     DateTime     @default(now())
}
