generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  project_manager
  accounting
}

enum ProjectStatus {
  active
  on_hold
  completed
}

enum ChangeOrderStatus {
  draft
  pending_review
  approved
  rejected
  synced
}

enum IntegrationStatus {
  connected
  disconnected
  error
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  firstName              String
  lastName               String
  passwordHash           String
  resetPasswordTokenHash String?      @unique
  resetPasswordExpiresAt DateTime?
  role                   UserRole
  dailyProjectBriefLimit Int          @default(3)
  projects               Project[]
  projectAccesses        ProjectAccess[]        @relation("ProjectAccessUser")
  grantedProjectAccesses ProjectAccess[]        @relation("ProjectAccessGrantedBy")
  projectAccessRequests  ProjectAccessRequest[] @relation("ProjectAccessRequestUser")
  handledProjectAccessRequests ProjectAccessRequest[] @relation("ProjectAccessRequestHandledBy")
  projectBriefGenerations ProjectBriefGeneration[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Project {
  id            String        @id @default(cuid())
  name          String
  code          String        @unique
  location      String
  status        ProjectStatus @default(active)
  archivedAt    DateTime?
  contractValue Decimal       @db.Decimal(12, 2)
  ownerId       String
  owner         User          @relation(fields: [ownerId], references: [id])
  changeOrders  ChangeOrder[]
  teamMembers   ProjectTeamMember[]
  documents     ProjectDocument[]
  tasks         ProjectTask[]
  riskFlags     ProjectRiskFlag[]
  documentProcessingRuns DocumentProcessingRun[]
  documentChunks DocumentChunk[]
  agentRuns     AgentRun[]
  agentMemoryEntries AgentMemoryEntry[]
  accessGrants  ProjectAccess[]
  accessRequests ProjectAccessRequest[]
  projectBriefGenerations ProjectBriefGeneration[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProjectAccess {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  grantedById String?
  user        User     @relation("ProjectAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  grantedBy   User?    @relation("ProjectAccessGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, projectId])
}

model ProjectAccessRequest {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  status      String   @default("pending")
  message     String?
  handledById String?
  handledAt   DateTime?
  user        User     @relation("ProjectAccessRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  handledBy   User?    @relation("ProjectAccessRequestHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectTeamMember {
  id        String   @id @default(cuid())
  projectId String
  name      String
  role      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  title     String
  kind      String
  summary   String
  aiSummary String?
  agentStatus String @default("idle")
  processingError String?
  lastProcessedAt DateTime?
  assignedTo String?
  url       String?
  storageKey String?
  fileName   String?
  contentType String?
  fileSize   Int?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processingRuns DocumentProcessingRun[]
  generatedTasks ProjectTask[]
  generatedRiskFlags ProjectRiskFlag[]
  chunks DocumentChunk[]
  agentRuns AgentRun[]
  agentMemoryEntries AgentMemoryEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  projectId  String
  documentId String
  chunkIndex Int
  content    String
  embeddingJson String?
  embeddingModel String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document   ProjectDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([documentId])
}

model ProjectTask {
  id               String   @id @default(cuid())
  projectId        String
  sourceDocumentId String?
  title            String
  description      String
  status           String   @default("open")
  assignedTo       String?
  createdByAgent   Boolean  @default(false)
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDocument   ProjectDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProjectRiskFlag {
  id               String   @id @default(cuid())
  projectId        String
  sourceDocumentId String?
  level            String
  title            String
  description      String
  status           String   @default("open")
  createdByAgent   Boolean  @default(false)
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDocument   ProjectDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DocumentProcessingRun {
  id               String   @id @default(cuid())
  projectId        String
  documentId       String
  status           String   @default("queued")
  extractionMethod String
  extractedTextChars Int?
  errorMessage     String?
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document         ProjectDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AgentRun {
  id         String   @id @default(cuid())
  projectId  String
  documentId String?
  trigger    String
  status     String   @default("running")
  summary    String?
  model      String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document   ProjectDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  steps      AgentStep[]
  memoryEntries AgentMemoryEntry[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([documentId])
}

model AgentStep {
  id        String   @id @default(cuid())
  runId     String
  stepType  String
  status    String   @default("completed")
  title     String
  details   String?
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
}

model AgentMemoryEntry {
  id         String   @id @default(cuid())
  projectId  String
  documentId String?
  runId      String?
  kind       String
  title      String
  content    String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document   ProjectDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  run        AgentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([documentId])
  @@index([runId])
}

model ChangeOrder {
  id                String            @id @default(cuid())
  projectId         String
  title             String
  description       String
  status            ChangeOrderStatus @default(draft)
  archivedAt        DateTime?
  amount            Decimal           @db.Decimal(12, 2)
  requestedBy       String
  assignedTo        String?
  externalReference String?
  aiSummary         String?
  project           Project           @relation(fields: [projectId], references: [id])
  attachments       ChangeOrderAttachment[]
  comments          ChangeOrderComment[]
  auditLogs         AuditLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ChangeOrderAttachment {
  id            String      @id @default(cuid())
  changeOrderId String
  title         String
  storageKey    String
  fileName      String
  contentType   String
  fileSize      Int
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ChangeOrderComment {
  id            String      @id @default(cuid())
  changeOrderId String
  authorName    String
  body          String
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProjectBriefGeneration {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

model IntegrationConnection {
  id          String            @id @default(cuid())
  provider    String            @unique
  status      IntegrationStatus @default(disconnected)
  lastSyncedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AuditLog {
  id            String       @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  changeOrderId String?
  metadata      Json?
  changeOrder   ChangeOrder? @relation(fields: [changeOrderId], references: [id])
  createdAt     DateTime     @default(now())
}
